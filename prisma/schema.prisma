generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id          String   @id @default(cuid())
  name        String
  game        String?
  profile     String   @default("cod_controller")
  duration    Int      @default(0)
  samples     Int      @default(0)
  status      String   @default("active")
  summary     String   @default("{}")
  avgLatency  Float    @default(0)
  maxLatency  Float    @default(0)
  avgDpc      Float    @default(0)
  maxDpc      Float    @default(0)
  avgIsr      Float    @default(0)
  maxIsr      Float    @default(0)
  avgFrametime Float   @default(0)
  minFps1pct  Float    @default(0)
  avgPing     Float    @default(0)
  packetLoss  Float    @default(0)
  score       Int      @default(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  snapshots   MetricSnapshot[]
  alerts      Alert[]
}

model MetricSnapshot {
  id         String   @id @default(cuid())
  sessionId  String
  timestamp  Int
  dpcLatency Float
  isrLatency Float
  frametime  Float
  fps        Float
  cpuUsage   Float
  gpuUsage   Float
  ramUsage   Float
  cpuTemp    Float
  gpuTemp    Float
  ping       Float
  jitter     Float
  packetLoss Float
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Alert {
  id        String   @id @default(cuid())
  sessionId String
  type      String
  severity  String
  message   String
  value     Float
  threshold Float
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model OptimizationTip {
  id          String   @id @default(cuid())
  category    String
  title       String
  description String
  impact      String
  difficulty  String
  createdAt   DateTime @default(now())
}